   "source": [
    "from ultralytics import YOLO\n",
    "\n",
    "# load pretrained model\n",
    "model = YOLO(\"yolov8n.pt\")\n",
    "\n",
    "# export to TensorFlow SavedModel at 1024 resolution\n",
    "model.export(\n",
    "    format=\"saved_model\",\n",
    "    imgsz=1024,\n",
    "    dynamic=False  # important\n",
    ")"
   ]
  }
